# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ---- Oracle DB (via SQLcl MCP server) ----
# Name of a SQLcl saved connection created with:
#   sql /nolog
#   conn -save DEBATE -savepwd debate@<your-tns-alias>
# Both seed.py and debate.py reach the DB through this saved connection.
ORACLE_MCP_CONNECTION=DEBATE

# Command SQLcl is invoked as (must be SQLcl 25.2+ on PATH).
SQLCL_COMMAND=sql

# The customer case under debate
CASE_CUSTOMER_ID=994221
